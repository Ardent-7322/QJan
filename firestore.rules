rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Offices — anyone can read, nobody can write directly from client
    match /offices/{officeId} {
      allow read: if true;
      allow write: if false;  // Only backend service account can write

      // Checkins subcollection — anyone can read, anyone can add
      // but cannot delete or update others' checkins
      match /checkins/{checkinId} {
        allow read: if true;
        allow create: if request.resource.data.keys().hasAll(['timestamp', 'status', 'session_id'])
                      && request.resource.data.status == 'active'
                      && request.resource.data.session_id is string
                      && request.resource.data.session_id.size() > 0;
        allow update: if resource.data.session_id == request.resource.data.session_id
                      && request.resource.data.status == 'left';
        allow delete: if false;
      }
    }
  }
}
